{
  "name": "archvault",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "docker:compose:up": "docker compose up -d db",
    "docker:compose:down": "docker compose down",
    "docker:compose:down:v": "docker compose down -v",
    "email:dev": "pnpm --filter @archvault/transactional dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:lint": "pnpm --filter @archvault/docs lint",
    "docs:lint:fix": "pnpm --filter @archvault/docs lint:fix",
    "docs:check": "pnpm --filter @archvault/docs check",
    "docs:dev": "pnpm --filter @archvault/docs dev",
    "docs:build": "pnpm --filter @archvault/docs build",
    "docs:preview": "pnpm --filter @archvault/docs preview"
  },
  "dependencies": {
    "@archvault/transactional": "workspace:*",
    "@base-ui/react": "^1.3.0",
    "@better-auth/scim": "^1.5.5",
    "@better-auth/sso": "^1.5.5",
    "@fontsource-variable/geist": "^5.2.8",
    "@icons-pack/react-simple-icons": "^13.12.0",
    "@opentelemetry/api": "^1.9.0",
