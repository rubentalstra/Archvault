# App
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # Generate a secret key: `pnpm dlx @better-auth/cli secret`

# Database
DATABASE_URL=postgres://c4user:c4pass@localhost:5432/c4platform

# OAuth (Phase 1c)
# Optional toggles per provider. When omitted, provider auto-enables only if both
# client ID + client secret are set.
AUTH_SOCIAL_GITHUB_ENABLED=
AUTH_SOCIAL_GOOGLE_ENABLED=
AUTH_SOCIAL_MICROSOFT_ENABLED=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Blocks (Phase 5)
GITHUB_PAT=
REGISTRY_REPO=

# Email (Phase 1c)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@archvault.dev

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=archvault
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_METRICS_EXPORT_INTERVAL=60000
OTEL_CONSOLE_EXPORTER=false

# OpenTelemetry Authentication
OTEL_AUTH_TYPE=none
OTEL_AUTH_BEARER_TOKEN=
OTEL_AUTH_BASIC_USER=
OTEL_AUTH_BASIC_PASS=
OTEL_AUTH_API_KEY_HEADER=x-api-key
OTEL_AUTH_API_KEY_VALUE=

# OpenTelemetry TLS
OTEL_EXPORTER_OTLP_CERTIFICATE=
OTEL_EXPORTER_OTLP_CLIENT_CERTIFICATE=
OTEL_EXPORTER_OTLP_CLIENT_KEY=
OTEL_TLS_INSECURE_SKIP_VERIFY=false

# OpenTelemetry Logs
OTEL_LOGS_ENABLED=false
